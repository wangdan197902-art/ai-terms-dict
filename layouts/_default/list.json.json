{{- /* 
   合并 JSON 模板：输出当前语种所有术语的数据
   用于 Fuse.js 客户端搜索
   注意：使用 .Site.RegularPages 按语言过滤，获取所有术语页面（含嵌套页面）
*/ -}}
{{- $terms := slice -}}
{{- range where .Site.RegularPages "Language.Lang" "==" .Language.Lang -}}
  {{- $term := dict
    "title" .Title
    "permalink" .Permalink
    "summary" (.Summary | plainify | truncate 200)
    "content" (.Plain | plainify | truncate 500)
    "categories" (delimit (.Params.categories | default slice) ", ")
    "tags" (delimit (.Params.tags | default slice) ", ")
  -}}
  {{- $terms = $terms | append $term -}}
{{- end -}}
{{- $data := dict "lang" .Language.Lang "terms" $terms -}}
{{- $data | jsonify (dict "indent" "  ") -}}
