{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AI Term Definition",
  "description": "Schema for AI term definitions in the dictionary",
  "type": "object",
  "required": ["term_id", "english", "category", "definition_short", "definition_long", "key_concepts", "use_cases", "difficulty"],
  "properties": {
    "term_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Unique term identifier, lowercase with underscores"
    },
    "english": {
      "type": "string",
      "minLength": 2,
      "maxLength": 100,
      "description": "English term name"
    },
    "language": {
      "type": "string",
      "enum": ["en", "es", "de", "ja", "fr", "zh"],
      "description": "ISO language code"
    },
    "term_name": {
      "type": "string",
      "description": "Localized term name"
    },
    "category": {
      "type": "string",
      "enum": ["basic_concepts", "training_techniques", "application_paradigms", "engineering_practice", "ethics_safety"],
      "description": "Term category"
    },
    "subcategory": {
      "type": "string",
      "description": "Optional subcategory"
    },
    "definition_short": {
      "type": "string",
      "minLength": 10,
      "maxLength": 300,
      "description": "One-sentence summary"
    },
    "definition_long": {
      "type": "string",
      "minLength": 50,
      "description": "Detailed definition"
    },
    "key_concepts": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 2,
      "maxItems": 8
    },
    "use_cases": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1,
      "maxItems": 6
    },
    "related_terms": {
      "type": "array",
      "items": {"type": "string"}
    },
    "code_example": {
      "type": ["string", "null"],
      "description": "Optional code example"
    },
    "difficulty": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "tags": {
      "type": "array",
      "items": {"type": "string"}
    },
    "source": {
      "type": "string",
      "enum": ["agnes_llm", "golden_sample", "golden_sample_fallback", "mock", "mock_fallback"]
    },
    "status": {
      "type": "string",
      "enum": ["published", "preview", "draft"],
      "default": "published"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "model": {
      "type": "string"
    }
  }
}
